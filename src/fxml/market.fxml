<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.Market">

    <Label fx:id="lblMoney" text="Argent : 0€" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
    <Label fx:id="lblMessage" text="Bienvenue au marché !" />

    <HBox alignment="CENTER" spacing="15.0">
        <Button text="Vendre Patates" onAction="#sellPatates" />
        <Button text="Vendre Maïs" onAction="#sellMais" />
    </HBox>

    <HBox alignment="CENTER" spacing="15.0">
        <Button text="Acheter Graine de Patate" onAction="#buyPatateSeed" />
        <Button text="Acheter Graine de Maïs" onAction="#buyMaisSeed" />
    </HBox>

    <Label text="ANIMAUX" style="-fx-font-weight: bold;" />
    <HBox spacing="10" alignment="CENTER">
        <VBox spacing="5" alignment="CENTER">
            <Label text="Poules" />
            <Button text="Acheter (200€)" onAction="#buyChicken" />
            <Button text="Vendre des oeufs" onAction="#sellEggs" />
        </VBox>
        <VBox spacing="5" alignment="CENTER">
            <Label text="Vaches" />
            <Button text="Acheter (400€)" onAction="#buyCow" />
            <Button text="Vendre du lait" onAction="#sellMilks" />
        </VBox>
    </HBox>

    <Button text="Retour à la Ferme" onAction="#goToFarm" />

</VBox>