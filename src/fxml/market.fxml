<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.Market">
    <Label fx:id="lblMoney" text="Monnaie : 0 €" style="-fx-font-size: 18px; -fx-text-fill: green;" />

    <Label text="LE MARCHÉ" style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <HBox alignment="CENTER" spacing="20.0">
        <Button text="Vendre toutes les Patates (100€)" onAction="#sellPatates" />
        <Button text="Vendre tout le Maïs (300€)" onAction="#sellMais" />
    </HBox>

    <Label fx:id="lblMessage" text="Bienvenue ! Que voulez-vous vendre ?" />

    <Button text="Retour à la Ferme" onAction="#goToFarm" style="-fx-background-color: #ddd;" />
</VBox>