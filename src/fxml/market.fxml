<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.Market">
    <Label text="BIENVENUE AU MARCHÉ" style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <HBox alignment="CENTER" spacing="10.0">
        <Button text="Vendre mes Patates" fx:id="btnSellPatate" />
        <Button text="Vendre mon Maïs" fx:id="btnSellMais" />
    </HBox>

    <Button text="Retour à la Ferme" onAction="#goToFarm" />
</VBox>